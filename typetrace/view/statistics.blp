using Gtk 4.0;

template $Statistics : Gtk.Box {
    orientation: vertical;
    halign: baseline;



    Gtk.DrawingArea drawing_area {
        height-request: 300;
        width-request: 400;
        margin-top: 10;
        margin-bottom: 10;
        margin-start: 10;
        margin-end: 10;
        halign: center;
        valign: center;
    }
}
