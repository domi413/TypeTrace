{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Typetrace",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/_install/bin/typetrace",
            "console": "integratedTerminal",
            "env": {
                "GSETTINGS_SCHEMA_DIR": "${workspaceFolder}/_install/share/glib-2.0/schemas"
            }
        }
    ]
}